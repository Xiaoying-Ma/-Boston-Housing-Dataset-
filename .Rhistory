library(MASS)
library(tidyverse)
library(plotly)
library(gridExtra)
library(corrplot)
library(scales)
library(RColorBrewer)
my.theme <- function(){
theme_minimal(base_size = 12) +
theme(
plot.title = element_text(face = "bold", size = 14, color = "#0d47a1", hjust = 0.5),
plot.subtitle = element_text(color = "#5f7ea6", size = 11),
plot.caption = element_text(color = "#78909c", size = 8, face = "italic"),
legend.position = "bottom",
legend.title = element_text(face = "bold", size = 10),
panel.grid.minor = element_blank(),
panel.grid.major = element_line(color = "#e8f1fb", linewidth = 0.3),
axis.title = element_text(size = 11, face = "bold", color = "#16324f"),
axis.text = element_text(size = 10, color = "#16324f"),
strip.text = element_text(face = "bold", size = 11),
strip.background = element_rect(fill = "#f3f8fe", color = NA)
)
}
ggplot(housing_clean, aes(x = chas_factor)) +
geom_bar(fill = "steelblue") +
geom_text(stat = "count", aes(label = after_stat(count)),
vjust = -0.5, size = 4) +
labs(title = "Distribution of Charles River Indicator",
x = "Bounds Charles River",
y = "Frequency") +
my.theme()
# Convert CHAS to factor for plotting and interpretation
housing_clean$chas_factor <- factor(housing_clean$chas,
levels = c(0, 1),
labels = c("No", "Yes"))
ggplot(housing_clean, aes(x = chas_factor)) +
geom_bar(fill = "steelblue") +
geom_text(stat = "count", aes(label = after_stat(count)),
vjust = -0.5, size = 4) +
labs(title = "Distribution of Charles River Indicator",
x = "Bounds Charles River",
y = "Frequency") +
my.theme()
